            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 5,
        })
        
        local valueText = new("TextLabel", {
            Name = "ValueText",
            Parent = frame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 10),
            Font = Enum.Font.Gotham,
            Text = tostring(value).."/"..tostring(max),
            TextColor3 = WHITE,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 5,
        })
        
        local sliderBg = new("Frame", {
            Name = "SliderBg",
            Parent = frame,
            BackgroundColor3 = WHITE,
            BorderSizePixel = 0,
            Position = UDim2.fromOffset(0, 12),
            Size = UDim2.new(1, 0, 0, 10),
            ZIndex = 5,
        })
        grad(sliderBg, DARK_KPS, 90)
        
        local fill = new("Frame", {
            Name = "Fill",
            Parent = sliderBg,
            BackgroundColor3 = WHITE,
            BorderSizePixel = 0,
            Size = UDim2.fromScale((value-min)/(max-min), 1),
            ZIndex = 6,
        })
        grad(fill, FILL_KPS, 90)
        
        local function setValue(v)
            value = math.clamp(math.floor(v + 0.5), min, max)
            fill.Size = UDim2.fromScale((value-min)/(max-min), 1)
            valueText.Text = tostring(value).."/"..tostring(max)..(cfg.Suffix or "")
            if cfg.Callback then cfg.Callback(value) end
        end
        
        local sliding = false
        local trackBtn = new("TextButton", { Parent=sliderBg, Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", ZIndex=7 })
        trackBtn.MouseButton1Down:Connect(function(x)
            sliding = true
            setValue(min + (max-min) * math.clamp((x-sliderBg.AbsolutePosition.X)/sliderBg.AbsoluteSize.X, 0, 1))
        end)
        
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
                setValue(min + (max-min) * math.clamp((i.Position.X-sliderBg.AbsolutePosition.X)/sliderBg.AbsoluteSize.X, 0, 1))
            end
        end)
        
        return { Get = function() return value end }
    end
    
    function sectionObj:Dropdown(cfg)
        cfg = cfg or {}
        local options = cfg.Items or {}
        local multiSelect = cfg.Multi or false
        local selected = cfg.Default or (multiSelect and {} or nil)
        local open = false
        
        local frame = new("Frame", {
            Parent = section,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 32),
            ZIndex = 4,
        })
        
        new("TextLabel", {
