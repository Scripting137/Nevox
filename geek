function WindowClass:SetActiveTab(name)
    for _, tab in ipairs(self.Tabs) do
        local active = (tab.name == name)
        tab.frame.BackgroundColor3 = active and ACTIVE_BG or SIDEBAR
        tab.line.Visible = active
        tab.page.Visible = active
    end
    self.ScrollFrame.CanvasPosition = Vector2.new(0,0)
    self.CurrentTab = name
end

function WindowClass:Init()
    if #self.Tabs > 0 then
        self:SetActiveTab(self.Tabs[1].name)
    end
    task.delay(0.5, function()
        notify("Welcome to L Hub!", 4)
    end)
end

