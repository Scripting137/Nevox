        local max = cfg.Max or 100
        local value = math.clamp(cfg.Default or min, min, max)
        
        local frame = new("Frame", {
            Parent = section,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 22),
            ZIndex = 4,
        })
        
        new("TextLabel", {
            Name = "SliderText",
            Parent = frame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 10),
