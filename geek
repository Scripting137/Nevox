function KeybindListClass:Add(key, featureName, getter)
    local lbl = new("TextLabel", {
        Parent = self.KeybindsFrame,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.fromOffset(7, 0),
        Size = UDim2.fromOffset(166, 12),
        Font = Enum.Font.Gotham,
        Text = key.." -- "..featureName.." / Disabled",
        TextColor3 = SUBTEXT,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 52,
    })
    table.insert(self.Entries, { label = lbl, key = key, feature = featureName, getter = getter })
    self:Update()
end

function KeybindListClass:Update()
    for _, e in ipairs(self.Entries) do
        local s = e.getter and e.getter() or false
        e.label.Text = e.key.." -- "..e.feature.." / "..(s and "Enabled" or "Disabled")
        for _, c in ipairs(e.label:GetChildren()) do if c:IsA("UIGradient") then c:Destroy() end end
        if s then
            grad(e.label, PURPLE_KPS)
            e.label.TextColor3 = WHITE
        else
            e.label.TextColor3 = SUBTEXT
        end
    end
    self.Frame.Size = UDim2.fromOffset(180, 22 + self.Layout.AbsoluteContentSize.Y + 4)
end

function KeybindListClass:SetVisible(visible)
    self.Frame.Visible = visible
end

