local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- ============================================================
-- Library Container
-- ============================================================

local Library = {}
Library.__index = Library

-- Colors (directly from template)
local BG        = Color3.fromRGB(6,6,6)
local SIDEBAR   = Color3.fromRGB(12,12,12)
local SEP_COL   = Color3.fromRGB(44,44,44)
local ACTIVE_BG = Color3.fromRGB(29,15,34)
local TOGBG     = Color3.fromRGB(45,45,45)
local NOTIF_BG  = Color3.fromRGB(14,14,20)
local WHITE     = Color3.fromRGB(255,255,255)
local SUBTEXT   = Color3.fromRGB(217,217,217)
local PURPLE    = Color3.fromRGB(174,90,199)

-- gradient keypoints
local PURPLE_KPS = { {0,173,153,255}, {1,174,90,199} }
local FILL_KPS   = { {0,175,80,199}, {0.5,129,59,147}, {1,124,61,145} }
local DARK_KPS   = { {0,14,17,17}, {1,7,8,9} }

-- ============================================================
-- Helpers
-- ============================================================

local function new(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        pcall(function() inst[k] = v end)
    end
    return inst
end

local function grad(parent, kps, rot)
    local g = new("UIGradient", { Parent = parent, Rotation = rot or 0 })
    local pts = {}
    for i, kp in ipairs(kps) do
        pts[i] = ColorSequenceKeypoint.new(kp[1], Color3.fromRGB(kp[2], kp[3], kp[4]))
    end
    g.Color = ColorSequence.new(pts)
    return g
end

local function makeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = i.Position
            startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

-- ============================================================
-- Notification System
-- ============================================================

local notifQ = {}
local notifActive = false
local Lhub -- Will be set in Window creation

local function notify(text, duration)
    duration = duration or 3
    table.insert(notifQ, { text = text, dur = duration })
    if notifActive then return end
    notifActive = true
    task.spawn(function()
        while #notifQ > 0 do
            local n = table.remove(notifQ, 1)
            
            local Notification = new("Frame", {
                Name = "Notification",
                Parent = Lhub,
                BackgroundColor3 = NOTIF_BG,
                BorderColor3 = Color3.fromRGB(0,0,0),
                BorderSizePixel = 0,
                Position = UDim2.new(1, 10, 0, 30),
                Size = UDim2.fromOffset(180, 22),
                ZIndex = 998,
            })

            local ntxt = new("TextLabel", {
                Name = "NotificationText",
                Parent = Notification,
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.fromOffset(10, 0),
                Size = UDim2.new(0.65, 56, 1, 0),
                Font = Enum.Font.Gotham,
                Text = n.text,
                TextColor3 = WHITE,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 999,
            })

            local nl = new("Frame", {
                Name = "Line",
                Parent = ntxt,
                BackgroundColor3 = WHITE,
                BorderColor3 = Color3.fromRGB(0,0,0),
                BorderSizePixel = 0,
                Position = UDim2.new(0, -4, 0.1, 0),
                Size = UDim2.new(0, 1, 0.8, 0),
                ZIndex = 999,
            })
            grad(nl, PURPLE_KPS)

            TweenService:Create(Notification, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(1, -190, 0, 30)
            }):Play()
            task.wait(n.dur)
            local tw = TweenService:Create(Notification, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 10, 0, 30)
            })
            tw:Play(); tw.Completed:Wait()
            Notification:Destroy()
            task.wait(0.05)
        end
        notifActive = false
    end)
end

