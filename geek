            Size = UDim2.new(1, 0, 0, 10),
            Font = Enum.Font.Gotham,
            Text = cfg.Name or "Dropdown",
            TextColor3 = WHITE,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 5,
        })
        
        local selBg = new("Frame", {
            Name = "Selected",
            Parent = frame,
            BackgroundColor3 = WHITE,
            BorderSizePixel = 0,
            Position = UDim2.fromOffset(0, 18),
            Size = UDim2.new(1, 0, 0, 14),
            ZIndex = 5,
        })
        grad(selBg, DARK_KPS, 90)
        
        local selText = new("TextLabel", {
            Name = "SelectedText",
            Parent = selBg,
            BackgroundTransparency = 1,
            Position = UDim2.fromOffset(3, 0),
            Size = UDim2.new(1, -20, 1, 0),
            Font = Enum.Font.Gotham,
            Text = multiSelect and (next(selected) and table.concat(selected, ", ") or "Select...") or (selected or "Select..."),
            TextColor3 = SUBTEXT,
            TextSize = 11,
            TextTruncate = Enum.TextTruncate.AtEnd,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 6,
        })
        
        local arrowImg = new("ImageLabel", {
            Name = "DropdownImage",
            Parent = selBg,
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -16, 0, 0),
            Size = UDim2.fromOffset(14, 14),
            Image = "rbxassetid://15818717266",
            ImageColor3 = Color3.fromRGB(223, 223, 223),
            Rotation = 0,
            ZIndex = 6,
        })
        
        local optHolder = new("Frame", {
            Name = "SelecterHolder",
            Parent = Lhub,
            BackgroundColor3 = WHITE,
            BorderSizePixel = 0,
            Visible = false,
            ZIndex = 999,
            ClipsDescendants = true,
        })
        grad(optHolder, DARK_KPS, 90)
        
        local optLayout = new("UIListLayout", { Parent=optHolder, SortOrder=Enum.SortOrder.LayoutOrder })
        new("UIPadding", { Parent=optHolder, PaddingTop=UDim.new(0,2), PaddingBottom=UDim.new(0,2), PaddingLeft=UDim.new(0,6) })
        
        local optLabels = {}
        
        local function updateDisplay()
            if multiSelect then
                if #selected == 0 then
                    selText.Text = "Select..."
                    selText.TextColor3 = SUBTEXT
                else
                    selText.Text = table.concat(selected, ", ")
                    selText.TextColor3 = WHITE
                end
            else
                selText.Text = selected or "Select..."
                selText.TextColor3 = selected and WHITE or SUBTEXT
            end
        end
        
        local function closeDD()
            open = false
            optHolder.Visible = false
            arrowImg.Rotation = 0
        end
        
        local function openDD()
            open = true
            arrowImg.Rotation = 180
            local ap = selBg.AbsolutePosition
            local as = selBg.AbsoluteSize
            local h = math.min(#options * 14 + 4, 120)
            optHolder.Position = UDim2.fromOffset(ap.X, ap.Y + as.Y + 2)
            optHolder.Size = UDim2.fromOffset(as.X, h)
            optHolder.Visible = true
        end
        
        for _, opt in ipairs(options) do
            local of = new("Frame", { Parent=optHolder, BackgroundTransparency=1, Size=UDim2.new(1,0,0,14), ZIndex=1000 })
            local ol = new("TextLabel", {
                Parent=of, BackgroundTransparency=1, Size=UDim2.fromScale(1,1),
                Font=Enum.Font.Gotham, Text=opt, TextColor3=SUBTEXT, TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=1001,
            })
            local ob = new("TextButton", { Parent=of, Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", ZIndex=1002 })
            ob.MouseEnter:Connect(function() ol.TextColor3 = PURPLE end)
            ob.MouseLeave:Connect(function() 
                local isSelected = multiSelect and table.find(selected, opt) or (selected == opt)
                ol.TextColor3 = isSelected and WHITE or SUBTEXT 
            end)
            ob.MouseButton1Click:Connect(function()
                if multiSelect then
                    local idx = table.find(selected, opt)
                    if idx then 
                        table.remove(selected, idx)
                        ol.TextColor3 = SUBTEXT
                    else 
                        table.insert(selected, opt)
                        ol.TextColor3 = WHITE 
                    end
                    updateDisplay()
                    if cfg.Callback then cfg.Callback(selected) end
                else
                    for _, l in pairs(optLabels) do l.TextColor3 = SUBTEXT end
                    selected = opt
                    ol.TextColor3 = WHITE
                    updateDisplay()
                    closeDD()
                    if cfg.Callback then cfg.Callback(opt) end
                end
            end)
            optLabels[opt] = ol
        end
        
        local togBtn = new("TextButton", { Parent=selBg, Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", ZIndex=7 })
        togBtn.MouseButton1Click:Connect(function() if open then closeDD() else openDD() end end)
        
        UserInputService.InputBegan:Connect(function(i)
            if open and i.UserInputType == Enum.UserInputType.MouseButton1 then
                local mp = i.Position
                local op = optHolder.AbsolutePosition
                local os = optHolder.AbsoluteSize
                local sp = selBg.AbsolutePosition
                local ss = selBg.AbsoluteSize
                local inO = mp.X >= op.X and mp.X <= op.X + os.X and mp.Y >= op.Y and mp.Y <= op.Y + os.Y
                local inS = mp.X >= sp.X and mp.X <= sp.X + ss.X and mp.Y >= sp.Y and mp.Y <= sp.Y + ss.Y
                if not inO and not inS then closeDD() end
            end
        end)
        
        return { Get = function() return selected end }
    end
    
